# Math Lab — server env for the feedback/submission route (app/api/feedback).
# Copy to .env.local (gitignored) for local dev, and set the same vars in your
# host's dashboard (e.g. Vercel → Project → Settings → Environment Variables)
# for production. These are read server-side only and never shipped to the browser.

# Slack bot token (starts with xoxb-). Create a Slack app, add the `chat:write`
# bot scope, install it to your workspace, and copy the "Bot User OAuth Token".
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Target channel. Use the channel ID (e.g. C0123ABCD — right-click the channel →
# View channel details → copy the ID at the bottom) or #channel-name.
# The bot must be a member of the channel: open the channel and /invite @your-bot.
SLACK_FEEDBACK_CHANNEL=C0123ABCD
